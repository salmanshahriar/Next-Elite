# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Public app URL (used by SEO, OAuth callbacks, baseURL of the API client).
# Defaults to BetterAuth URL or the domain in src/features/site/site.config.json.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# BetterAuth
# ----------------------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-or-longer-secret

# ----------------------------------------------------------------------------
# Google OAuth (optional)
# ----------------------------------------------------------------------------
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to "true" to render the "Sign in with Google" button.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ----------------------------------------------------------------------------
# RBAC: comma-separated emails that get the admin role on sign-in.
# ----------------------------------------------------------------------------
AUTH_ADMIN_EMAILS=admin@yourdomain.com
NEXT_PUBLIC_AUTH_ADMIN_EMAILS=admin@yourdomain.com

# ----------------------------------------------------------------------------
# Demo mode
# ----------------------------------------------------------------------------
# When "true", the login page renders the demo credentials panel and
# auto-registers the seed accounts in src/features/auth/demo/accounts.ts on
# first sign-in. Flip to "false" (or delete src/features/auth/demo/) for prod.
NEXT_PUBLIC_DEMO_MODE=true

# ----------------------------------------------------------------------------
# Upstash Redis (optional – enables rate limiting / persistent sessions)
# ----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# Sentry (optional)
# ----------------------------------------------------------------------------
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
