{
  "name": "nextjs-elite-boilerplate",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "next experimental-analyze",
    "analyze:webpack": "ANALYZE=true next build --webpack",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "check": "npm run typecheck && npm run lint && npm run format && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:webkit": "playwright test --project=webkit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@better-auth/memory-adapter": "^1.6.9",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "^10.50.0",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.35.0",
    "@vercel/analytics": "2.0.1",
    "better-auth": "^1.6.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "next": "^16.2.4",
    "next-themes": "0.4.6",
    "pino": "^9.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.56.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "jsdom": "28.1.0",
    "lefthook": "^1.8.0",
    "lint-staged": "^15.2.0",
    "pino-pretty": "^11.2.0",
    "postcss": "^8.5.12",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "^7.8.0",
    "tailwindcss": "4.2.1",
    "tsx": "^4.20.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
